{
  "crons": [
    {
      "path": "/api/cron/poll",
      "schedule": "*/1 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "regions": ["sin1"]
}
